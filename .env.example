# Copy to .env and fill in real values.

# LLM provider: openai | anthropic | deepseek
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-openai-key-here

# Single-model mode: set LLM_MODEL and leave LLM_MODELS empty.
LLM_MODEL=gpt-4o

# Multi-model mode: set LLM_MODELS to a JSON map of friendly-name → spec
# and LLM_DEFAULT_MODEL to one of those keys. Each spec can be:
#   - a plain model id string (for non-reasoning models), or
#   - an object {"model": "...", "effort": "low|medium|high"} which also
#     pins the reasoning effort for gpt-5 / o-series models.
# The UI shows the friendly names in the model switcher in each chat
# header. Leave LLM_MODELS empty to fall back to single-model mode.
# Example:
#   LLM_MODELS={"Quick":{"model":"gpt-5-mini","effort":"low"},"Medium":{"model":"gpt-5.4","effort":"medium"},"Smart":{"model":"gpt-5.4","effort":"high"}}
#   LLM_DEFAULT_MODEL=Medium
LLM_MODELS=
LLM_DEFAULT_MODEL=

# Hard daily spend cap in USD (per PRD §6.7)
DAILY_BUDGET_USD=5

# Session password for the web app (per PRD §7.1)
AUTH_PASSWORD=changeme

# Where the vault lives ON THE HOST. Docker bind-mounts this directory into
# the backend container at VAULT_PATH. Keep this OUTSIDE the code repo so the
# vault (your notes) stays portable and doesn't entangle with the codebase.
# Examples:
#   VAULT_HOST_PATH=${HOME}/bengt-vault
#   VAULT_HOST_PATH=${HOME}/Documents/obsidian-vault   # reuse an existing Obsidian vault
# If unset, defaults to ./vault inside this repo (fine for quick experiments).
VAULT_HOST_PATH=${HOME}/bengt-vault

# Vault location INSIDE the backend container. Leave as-is unless you know why.
VAULT_PATH=/app/vault

# Reserved for future inbox scanning (unused in v0.1 per PRD §8.2)
INBOX_SCAN_INTERVAL_MINUTES=15

# IANA timezone the agent uses when it answers date/time questions.
# Default is UTC; for Sweden use Europe/Stockholm (handles summer/winter DST).
TIMEZONE=UTC

# After a fresh conversation's first assistant turn, auto-generate a short
# title via a tiny extra LLM call. Set AUTO_TITLE=false to disable.
AUTO_TITLE=true
